{
  "name": "forgejo-status",
  "version": "0.2.0-dev",
  "description": "Push commit check status to Forgejo",
  "license": "MIT",
  "author": "Antti Kivi <antti@anttikivi.com>",
  "repository": {
    "type": "git",
    "url": "ssh://git@codeberg.org/anttikivi/forgejo-status.git"
  },
  "type": "module",
  "scripts": {
    "build": "rm -rf ./dist && rolldown -c",
    "bundle": "npm run format && npm run build",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "npm run format:check && oxlint"
  },
  "dependencies": {
    "@actions/core": "3.0.0",
    "@actions/github": "9.0.0"
  },
  "devDependencies": {
    "@types/node": "22.13.5",
    "oxfmt": "0.35.0",
    "oxlint": "1.50.0",
    "oxlint-tsgolint": "0.14.2",
    "rolldown": "1.0.0-rc.5",
    "rollup-plugin-esbuild": "6.2.1",
    "typescript": "5.9.3"
  }
}
