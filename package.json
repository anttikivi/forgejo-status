{
  "name": "forgejo-status",
  "version": "0.1.0-dev",
  "description": "Push commit check status to Forgejo",
  "repository": {
    "type": "git",
    "url": "ssh://git@codeberg.org/anttikivi/forgejo-status.git"
  },
  "license": "MIT",
  "author": "Antti Kivi <antti@anttikivi.com>",
  "type": "module",
  "scripts": {
    "build": "rm -rf ./dist && rolldown -c",
    "bundle": "npm run format && npm run build",
    "format": "NODE_OPTIONS=\"--experimental-strip-types\" prettier --write .",
    "format:check": "prettier --write .",
    "lint": "npm run format:check && NODE_OPTIONS=\"--experimental-strip-types\" eslint . --flag unstable_native_nodejs_ts_config"
  },
  "dependencies": {
    "@actions/core": "3.0.0",
    "@actions/github": "9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "22.13.5",
    "eslint": "10.0.2",
    "globals": "17.3.0",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-packagejson": "3.0.0",
    "rolldown": "1.0.0-rc.5",
    "rollup-plugin-esbuild": "6.2.1",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  }
}
